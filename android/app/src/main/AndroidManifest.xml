<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. صلاحيات الإنترنت والشراء -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- للشراء داخل التطبيق -->
    <uses-permission android:name="com.android.vending.BILLING" />

    <!-- 2. صلاحيات اللانشر وتخصيص الواجهة -->
    <!-- عشان يبقى اللانشر الافتراضي -->
    <uses-permission android:name="android.permission.SET_PREFERRED_APPLICATIONS"/>
    <!-- تغيير الخلفية -->
    <uses-permission android:name="android.permission.SET_WALLPAPER"/>
    <!-- فتح شريط الإشعارات -->
    <uses-permission android:name="android.permission.EXPAND_STATUS_BAR"/>
    <!-- عرض الويدجت -->
    <uses-permission android:name="android.permission.BIND_APPWIDGET" />
    <!-- إضافة اختصارات -->
    <uses-permission android:name="com.android.launcher.permission.INSTALL_SHORTCUT" />

    <!-- 3. الوصول للملفات والتطبيقات -->
    <!-- قراءة الملفات/الصور -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <!-- جلب قائمة التطبيقات المثبتة -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <!-- معرفة المهام الشغالة (صلاحية قديمة بس شغالة) -->
    <uses-permission android:name="android.permission.GET_TASKS" />

    <!-- 4. نظام المنبه والرخامة (المهام الحرجة) -->
    <!-- ضبط منبه دقيق -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- استخدام المنبه في أندرويد 13+ -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- فتح شاشة كاملة وقت المنبه -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <!-- الرسم فوق التطبيقات (الطبقة العلوية) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- 5. ضمان الاستمرارية (عشان ميتقفلش) -->
    <!-- التشغيل التلقائي بعد ريستارت الموبايل -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- منع المعالج من النوم وقت الشغل -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- تشغيل خدمة في الواجهة -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <application android:label="سُنة" android:name="${applicationName}" android:icon="@mipmap/ic_launcher">
        <activity android:name=".MainActivity" android:exported="true" android:launchMode="singleInstance" android:taskAffinity="" android:theme="@style/LaunchTheme" android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode" android:hardwareAccelerated="true" android:windowSoftInputMode="adjustResize">

            <meta-data android:name="io.flutter.embedding.android.NormalTheme" android:resource="@style/NormalTheme" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>

                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <meta-data android:name="flutterEmbedding" android:value="2" />
    </application>

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>

            <action android:name="android.intent.action.MAIN" />
        </intent>
        <package android:name="net.pulsesecure.pulsesecure" />
    </queries>
</manifest>
